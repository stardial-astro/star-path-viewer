{
  "name": "star-path-viewer",
  "version": "1.3.1",
  "homepage": "https://star-path-viewer.pages.dev/",
  "description": "Astronomical tool for tracing the positions of planets and stars on any chosen date in the ancient or future sky.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:ssl": "HTTPS=true vite --host",
    "dev:w": "bash run-wrangler.sh dev",
    "dev:w:ssl": "bash run-wrangler.sh dev:ssl",
    "build": "vite build",
    "preview": "vite preview --host --strictPort",
    "preview:ssl": "HTTPS=true vite preview --host --strictPort",
    "preview:w": "bash run-wrangler.sh preview",
    "preview:w:ssl": "bash run-wrangler.sh preview:ssl",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/system": "^7.3.9",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-query-devtools": "^5.96.1",
    "axios": "1.15.0",
    "canvg": "^4.0.3",
    "dompurify": "^3.3.3",
    "fetch-jsonp": "^1.4.0",
    "file-saver": "^2.0.5",
    "html-react-parser": "^6.0.1",
    "i18next": "^26.0.7",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.6",
    "jspdf": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.2",
    "react-router": "^7.13.2",
    "svg2pdf.js": "^2.7.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "rolldown": "^1.0.0-rc.13",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.2",
    "vitest-canvas-mock": "^1.1.4",
    "wrangler": "^4.84.0"
  },
  "resolutions": {
    "serialize-javascript": ">=7.0.5"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "yarn@4.13.0"
}
