/index.html
  Cache-Control: public, no-cache

/sw.js
  Cache-Control: public, no-cache

# Cache hashed assets - cache in browser for 1 year, never change when fresh
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache logos - cache in browser for 7 days
/favicon.*
  Cache-Control: public, max-age=604800

/icons/*.png
  Cache-Control: public, max-age=604800

/*.svg
  Cache-Control: public, max-age=604800

# Cache the HIP ident list (standard fetch) - cache in browser for 1 year, never change when fresh
/data/hip*.json
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Cache the JSON tzData (standard fetch) - keep in CDN for 7 days, cache in browser for 1 hour,
# serve the stale cache for up to 7 days while updating in the background
/data/timezones*.json
  Cache-Control: public, s-maxage=604800, max-age=3600, stale-while-revalidate=604800
  Access-Control-Allow-Origin: *

# Cache the binary geoData (Range request) - cache in browser for 7 days
/data/timezones*.dat
  Cache-Control: public, max-age=604800
  Accept-Ranges: bytes
  Access-Control-Allow-Origin: *
